# ─────────────────────────────────────────────
# BioOps Twin — .gitignore
# ─────────────────────────────────────────────

# Python bytecode & environments
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
build/

# Runtime data (regenerated on each run)
audit.jsonl
*.log

# ChromaDB vector store (regenerated by RAG pipeline)
data/rag_db/chroma/

# Secrets & credentials
.env
.env.*
*.key
*.pem

# IDE & editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS artifacts
.DS_Store
Thumbs.db

# Hugging Face
.huggingface/
